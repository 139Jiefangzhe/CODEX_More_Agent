{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@server/*": ["./server/*"],
      "@client/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["server/**/*.ts", "client/src/**/*.ts", "client/src/**/*.tsx", "shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
