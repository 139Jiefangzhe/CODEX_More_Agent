# Dashboard 环境变量配置
# 复制为 .env 后修改

# 服务器配置
PORT=3100
HOST=127.0.0.1

# 数据库路径（SQLite）
DATABASE_URL=./data/dashboard.db

# OpenAI 配置
# Dashboard 会在启动工作会话时读取这些值：
# - gpt-5.4 负责总控、架构规划、评审
# - gpt-5.3-codex 负责具体编码执行
OPENAI_API_KEY=
OPENAI_BASE_URL=https://www.heiyucode.com
DASHBOARD_CONTROLLER_MODEL=gpt-5.4
CODEX_MODEL=gpt-5.3-codex
CODEX_TIMEOUT=600
CODEX_PROVIDER=responses

# 当 CODEX_PROVIDER=mcp 时生效
# 默认会尝试自动定位 ../mcp-server-codex/dist/index.js
CODEX_MCP_COMMAND=node
# CODEX_MCP_ARGS=../mcp-server-codex/dist/index.js
# CODEX_MCP_CWD=../mcp-server-codex

# 控制面调度模式：
# direct = 接口直接拉起 loop（默认）
# queue  = 接口只入队，由后台 dispatcher 拉起 loop（更接近控制面/展示面解耦）
CONTROL_PLANE_MODE=direct

# 必填：写接口鉴权 Token（前端请求需带 x-dashboard-token）
DASHBOARD_TOKEN=change_me_dashboard_token

# 可选：项目根目录白名单（逗号分隔）
# 仅允许在这些目录下创建/更新项目
WORKSPACE_ROOTS=/data/claude_moreagent

# 可选：事件总线类型（emitter | redis）
EVENT_BUS_TYPE=emitter

# 可选：Redis 连接（EVENT_BUS_TYPE=redis 时需要）
REDIS_URL=redis://localhost:6379
